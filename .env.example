## Public URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

## Supabase (server-side)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

## Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Optional: used only when testing with Stripe CLI
STRIPE_WEBHOOK_SECRET_CLI=whsec_your_cli_webhook_secret

STRIPE_PRO_PRICE_ID=price_your_pro_price_id
STRIPE_TEAM_PRICE_ID=price_your_team_price_id

# Optional public aliases if you prefer exposing price IDs client-side
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_your_pro_price_id
NEXT_PUBLIC_STRIPE_TEAM_PRICE_ID=price_your_team_price_id

## GitHub OAuth
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback

## Resend / Email
RESEND_API_KEY=re_your_resend_api_key
# The email address shown in the "From" field for invitation emails
INVITATION_EMAIL_FROM=Archassistant <invites@your-domain.com>
# Fallback "from" address if INVITATION_EMAIL_FROM is not set
RESEND_FROM_EMAIL=Archassistant <noreply@your-domain.com>

## Analytics (PostHog)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

## LLM Provider (Groq or similar)
GROQ_API_KEY=your_groq_api_key

# IMPORTANT:
# - Do NOT commit your real .env file to git.
# - Copy this file to ".env" and fill in real values locally and in your hosting provider.
